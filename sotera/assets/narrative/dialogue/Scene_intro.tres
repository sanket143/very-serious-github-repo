script = ExtResource("1_agtrx")
dialogue_lines = Array[String](["Welcome Everybody! Thank you so much for coming today!", "Welcome! To Wheel of Damnation!", "We've got a very special guest with us today. Lets see if she has what it takes to survive...", "THE WHEEL OF DAMNATION!!!", "That's right! You're watching the best and only show in the nine layers! Made specifically for your demonic entertainment by our terrifying producer!", "Now folks, what should she do?", "SPIN THAT WHEEL!!"])
